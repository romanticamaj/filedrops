PORT=3000

# The gate passphrase you type to get in. Choose it, remember it, share it with
# anyone you let in. Make it long enough not to guess.
ACCESS_PASSPHRASE=change-me-to-a-long-passphrase

# Server-side key that signs the login cookie. You never type this — just make it
# random and keep it secret. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Changing it logs everyone out (they re-enter the passphrase once).
COOKIE_SECRET=change-me-to-a-random-32+-char-string

DATA_DIR=./data
MAX_FILE_MB=2048
ROOM_IDLE_DAYS=7
COOKIE_MAX_AGE_DAYS=90

# Set to false ONLY for local http / LAN use; keep true in production (behind HTTPS).
SECURE_COOKIE=true

# Cookie that remembers each visitor's language choice (en / zh-Hant). The
# defaults are right for a standalone install; set a name/domain only if you run
# several apps under one parent domain and want them to share the choice.
LANG_COOKIE=fd_lang
# LANG_COOKIE_DOMAIN=.example.com
